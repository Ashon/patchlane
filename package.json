{
  "name": "agent-fleet",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm --filter @agent-fleet/api dev\" \"pnpm --filter @agent-fleet/web dev\"",
    "dev:api": "pnpm --filter @agent-fleet/api dev",
    "dev:web": "pnpm --filter @agent-fleet/web dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.7",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.0"
  }
}
