{
  "name": "patchlane",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm --filter @patchlane/api dev\" \"pnpm --filter @patchlane/web dev\"",
    "dev:api": "pnpm --filter @patchlane/api dev",
    "dev:desktop": "concurrently -n web,desktop -c magenta,green \"pnpm dev:web\" \"pnpm --filter @patchlane/desktop dev\"",
    "dev:web": "pnpm --filter @patchlane/web dev",
    "build": "pnpm -r build",
    "build:desktop": "VITE_BASE=./ pnpm --filter @patchlane/web build && pnpm --filter @patchlane/desktop build",
    "desktop": "pnpm --filter @patchlane/desktop start",
    "test:e2e": "tsx --tsconfig tsconfig.e2e.json --test \"e2e/**/*.test.ts\"",
    "perf:e2e": "tsx --tsconfig tsconfig.e2e.json e2e/agent-issue-performance.ts",
    "e2e:existing-issues": "tsx --tsconfig tsconfig.e2e.json e2e/agent-existing-issues-reset.ts",
    "e2e:agent-regression": "tsx --tsconfig tsconfig.e2e.json e2e/agent-existing-issues-reset.ts",
    "format": "prettier --write . --ignore-path .gitignore --ignore-unknown",
    "format:check": "prettier --check . --ignore-path .gitignore --ignore-unknown",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.7",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.0"
  }
}
